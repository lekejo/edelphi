embed-server --server-config=standalone-full-ha.xml

/system-property=java.net.preferIPv4Stack:add(value=true)
/subsystem=messaging-activemq/server=default:write-attribute(name=cluster-password,value="${env.CLUSTER_PASSWORD}")

/interface=private:write-attribute(name=inet-address,value=0.0.0.0)
/interface=management:write-attribute(name=inet-address,value=0.0.0.0)
/interface=public:write-attribute(name=inet-address,value=0.0.0.0)
/interface=unsecure:write-attribute(name=inet-address,value=0.0.0.0)

stop-embedded-server
