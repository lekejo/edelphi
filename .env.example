# Copy this file to .env and fill in the values before running docker compose
# cp .env.example .env  (Linux/Mac)
# copy .env.example .env  (Windows)

# Hostname for the application (e.g. localhost for local dev)
HOST=localhost

# Database settings (match the MySQL service in docker-compose.yml)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=edelphi
DB_USERNAME=edelphi
DB_PASSWORD=password

# Cluster password (any random string for local dev)
CLUSTER_PASSWORD=changeme123

# Keycloak settings
KEYCLOAK_REALM=edelphi
KEYCLOAK_RESOURCE=edelphi-api
KEYCLOAK_SECRET=changeme-secret
KEYCLOAK_URL=http://keycloak:8080

# SMTP / email settings (leave blank to disable email sending)
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_TLS=false

# Contact email shown in the application
CONTACT_EMAIL=admin@localhost

# Kubernetes namespace (leave blank for local Docker dev)
KUBERNETES_NAMESPACE=

# JVM memory options
JAVA_OPTS=-Xms512m -Xmx2048m

# WildFly extra options (leave blank for default)
WILDFLY_EXTRA_OPTS=

# Reports settings (leave blank to use defaults)
OVERRIDE_REPORTS_URL=
SAVE_REPORTS_ON_DISK=false

# Google Picker integration (leave blank to disable)
GOOGLE_PICKER_API_KEY=
GOOGLE_PICKER_CLIENT_ID=
GOOGLE_PICKER_APP_ID=
